
@{
    ViewBag.Title = "Dashboard";
}

<div class="container mt-5">

    <h2 class="mb-4">Dashboard</h2>

    <div class="row">

        <div class="col-md-4">
            <div class="card text-white bg-primary p-3 mb-3">
                <h5>Total Users</h5>
                <h3>100</h3>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card text-white bg-success p-3 mb-3">
                <h5>Active Users</h5>
                <h3>80</h3>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card text-white bg-danger p-3 mb-3">
                <h5>Blocked Users</h5>
                <h3>20</h3>
            </div>
        </div>

    </div>
</div>

